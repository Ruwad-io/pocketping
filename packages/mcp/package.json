{
  "name": "@pocketping/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for PocketPing — manage and answer your live chats from Claude, Cursor, or any MCP client.",
  "type": "module",
  "bin": {
    "pocketping-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "pocketping",
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "ai",
    "agent",
    "live-chat",
    "support"
  ],
  "author": "PocketPing",
  "license": "MIT",
  "homepage": "https://pocketping.io",
  "bugs": {
    "url": "https://github.com/Ruwad-io/pocketping/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruwad-io/pocketping.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "release": {
    "extends": "semantic-release-monorepo",
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "npm pkg set version=${nextRelease.version}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
