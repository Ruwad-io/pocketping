{
  "name": "@pocketping/react",
  "version": "0.1.0",
  "type": "module",
  "description": "React bindings for the PocketPing chat widget (provider + hook)",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist && find src -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' | xargs rm -f 2>/dev/null || true",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pocketping/widget": ">=2.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@pocketping/widget": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "chat",
    "widget",
    "react",
    "support",
    "customer-service",
    "pocketping"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruwad-io/pocketping.git",
    "directory": "packages/react"
  },
  "release": {
    "extends": "semantic-release-monorepo",
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "npm pkg set version=${nextRelease.version}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
